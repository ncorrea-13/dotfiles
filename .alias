# alias

# Binary
alias ls='lsd'
alias cat='batcat'
alias cd='z'
alias up='topgrade'

# flatpak
alias bw="flatpak run --command=bw com.bitwarden.desktop"
alias ncspot='flatpak run io.github.hrkfdn.ncspot'

# Utils
alias pomodoro='tomatoshell -f -t 45.00 -d 15.00 -n 4'
alias health='echo "\e[1;34m--- CPU Status ---\e[0m" && grep MHz /proc/cpuinfo | head -n 4 && echo "\e[1;33m--- Temp ---\e[0m" && sensors | grep "Package id 0" && echo "\e[1;32m--- Battery ---\e[0m" && sudo tlp-stat -b | grep -E "Percentage|status|cycle_count"'
alias bw-auth='export BW_SESSION=$(bw unlock --raw)'

# open-rc
alias rcs='sudo rc-service'
alias rcu='sudo rc-update'
alias rclist='rc-update show -v'
alias rccrash='rc-status --crashed'

# Print services
alias cups-on='sudo rc-service cups start && sudo rc-service cups-browsed start'
alias cups-off='sudo rc-service cups stop && sudo rc-service cups-browsed stop'
alias cups-stat='rc-service cups status'

# Virt services
alias vm-on='sudo rc-service libvirtd start && sudo rc-service virtlogd start'
alias vm-off='sudo rc-service libvirtd stop && sudo rc-service virtlogd stop'

# Podman socket
alias pod-on='sudo rc-service podman-service start'
alias pod-off='sudo rc-service podman-service stop'

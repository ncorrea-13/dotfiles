# alias

# rc
rc() {
    local ADMIN_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    doas env PATH="$ADMIN_PATH" "$@"
}

# Binary
alias ls='lsd'
alias cat='batcat'
alias cd='z'
alias up='topgrade'

# flatpak
alias bw="flatpak run --command=bw com.bitwarden.desktop"
alias ncspot='flatpak run io.github.hrkfdn.ncspot'

# nchat
alias telegram='nchat -d ~/.config/nchat-telegram'
alias signal='nchat -d ~/.config/nchat-signal'
alias whatsapp='nchat -d ~/.config/nchat-whatsapp'

# Utils
alias pomodoro='tomatoshell -f -t 45.00 -d 15.00 -n 4'
alias health='echo "\e[1;34m--- CPU Status ---\e[0m" && grep MHz /proc/cpuinfo | head -n 4 && echo "\e[1;33m--- Temp ---\e[0m" && sensors | grep "Package id 0" && echo "\e[1;32m--- Battery ---\e[0m" && sudo tlp-stat -b | grep -E "Percentage|status|cycle_count"'
alias bw-auth='export BW_SESSION=$(bw unlock --raw)'

# open-rc
alias rcs='rc rc-status'
alias rcu='rc rc-update'
alias rcsv='rc rc-service'
alias rclist='rc rc-update show -v'
alias rccrash='rc-status --crashed'

# Print services
alias cups-on='rc rc-service cups start && rc rc-service cups-browsed start'
alias cups-off='rc rc-service cups stop && rc rc-service cups-browsed stop'
alias cups-stat='rc-service cups status'

# Virt services
alias vm-on='rc rc-service libvirtd start && rc rc-service virtlogd start'
alias vm-off='rc rc-service libvirtd stop && rc rc-service virtlogd stop'

# Black arch VM
alias arch-on='virsh --connect qemu:///system start archlinux'
alias arch-off='virsh --connect qemu:///system shutdown archlinux'
alias arch-ssh='ssh arch-vm'
alias arch-status='virsh --connect qemu:///system list --all'

alias arch-work='virsh --connect qemu:///system start archlinux && echo "Esperando a que la VM responda..." && until nc -z 192.168.122.207 22; do sleep 1; done && ssh arch@192.168.122.207'

# Podman socket
alias pod-on='rc rc-service podman-service start'
alias pod-off='rc rc-service podman-service stop'

alias ls-tui='localsend-rs tui --alias "Devuan Pc"'

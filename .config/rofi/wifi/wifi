# в”¬в”Җв”җв”Ңв”Җв”җв”Ңв”Җв”җв”¬  в”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”җв”Ңв”Ңв”Җв”җв”¬в”Ңв”Җв”җв”Ңв”Җв”җ
# в”ңв”¬в”ҳв”Ӯ в”Ӯв”ңв”Ө в”Ӯ  в”Ӯ  в”Ӯ в”Ӯв”Ӯв”Ӯв”Ӯв”ңв”Ө в”Ӯв”Ӯ в”¬в””в”Җв”җ
# в”ҙв””в”Җв””в”Җв”ҳв””  в”ҙ  в””в”Җв”ҳв””в”Җв”ҳв”ҳв””в”ҳв””  в”ҙв””в”Җв”ҳв””в”Җв”ҳ

# rofi config without entry so to make select from available options only
rofiprompt=~/.config/rofi/wifi/prompt.rasi
# normal rofi menu
rofidmenu=~/.config/rofi/wifi/dmenu.rasi
# rofi config for password
rofipass=~/.config/rofi/wifi/passwd.rasi

# в”Ңв”Җв”җв”Ңв”¬в”җв”Ңв”Җв”җв”Ңв”¬в”җв”¬ в”¬в”Ңв”Җв”җ
# в””в”Җв”җ в”Ӯ в”ңв”Җв”Ө в”Ӯ в”Ӯ в”Ӯв””в”Җв”җ
# в””в”Җв”ҳ в”ҙ в”ҙ в”ҙ в”ҙ в””в”Җв”ҳв””в”Җв”ҳ

# Power Status
flag=$(cat /sys/class/net/wl*/flags)

if [ "$flag" = "0x1003" ]; then
  power="On"
else
  power="Off"
fi

# Connection Status
current_ssid=$(nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d: -f2)

if [ -n "$current_ssid" ]; then
  wifi_display_status="Connected to: $current_ssid"
else
  wifi_display_status="Disconnected"
fi

# в”Ңв”Җв”җв”Ңв”Җв”җв”¬ в”¬в”Ңв”Җв”җв”¬в”Җв”җ
# в”ңв”Җв”ҳв”Ӯ в”Ӯв”Ӯв”Ӯв”Ӯв”ңв”Ө в”ңв”¬в”ҳ
# в”ҙ  в””в”Җв”ҳв””в”ҙв”ҳв””в”Җв”ҳв”ҙв””в”Җ

powertoggle=$([ "$flag" = "0x1003" ] && echo "Power Off" || echo "Power On")

powerswitch() {
  if [ "$powertoggle" = "Power Off" ]; then
    nmcli radio wifi off
  elif [ "$powertoggle" = "Power On" ]; then
    nmcli radio wifi on
  fi
}

# в”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”җв”Ңв”Ңв”җв”Ңв”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”¬в”җ
# в”Ӯ  в”Ӯ в”Ӯв”Ӯв”Ӯв”Ӯв”Ӯв”Ӯв”Ӯв”ңв”Ө в”Ӯ   в”Ӯ
# в””в”Җв”ҳв””в”Җв”ҳв”ҳв””в”ҳв”ҳв””в”ҳв””в”Җв”ҳв””в”Җв”ҳ в”ҙ

connections() {
  list=$(nmcli --fields "SECURITY,SSID" device wifi list | tail -n +2 | sed "s/  */ /g" | sed -E "s/WPA*.?/пЎҖ/g" | sed "s/^--/п ҝ/g" | sed "s/пЎҖ пЎҖ/пЎҖ/g")
  networks=$(printf "$list" | rofi -config $rofiprompt -dmenu -i -hover-select -p "Select Wifi Network
$status")
  wifi=$(echo "$networks" | sed "s/п ҝ //g" | sed "s/пЎҖ //g" | xargs)
  [ -z "$networks" ] && exit

  # Check if the selected network is already known
  if nmcli connection show | grep -q "\b$wifi\b"; then
    nmcli dev wifi con "$wifi" && printf "exit" | rofi -config $rofiprompt -dmenu -only-match -i -p "Successfully Connected to $wifi" && exit
  fi

  nopass="No Password"
  pass=$(printf "$nopass\nCancel" | rofi -config $rofipass -dmenu -i -hover-select -password -p "Wifi Password")

  if [ "$pass" = "" ]; then
    exit
  elif [ "$pass" = "$nopass" ]; then
    nmcli dev wifi con "$wifi" && printf "exit" | rofi -config $rofiprompt -dmenu -only-match -i -p "Successfully Connected to $wifi" && exit
  elif [ "$pass" = "Cancel" ]; then
    exit
  else
    nmcli dev wifi con "$wifi" password "$pass" && printf "exit" | rofi -config $rofiprompt -dmenu -i -only-match -p "Successfully Connected to $wifi" && exit
  fi

  printf "exit" | rofi -config $rofiprompt -dmenu -i -p -only-match "Failed to Connect $wifi" && exit
}

# в”Ңв”¬в”җв”Ңв”Җв”җв”Ңв”җв”Ңв”¬ в”¬в”Ңв”Җв”җв”¬
# в”Ӯв”Ӯв”Ӯв”ңв”Җв”Өв”Ӯв”Ӯв”Ӯв”Ӯ в”Ӯв”ңв”Җв”Өв”Ӯ
# в”ҙ в”ҙв”ҙ в”ҙв”ҳв””в”ҳв””в”Җв”ҳв”ҙ в”ҙв”ҙв”Җв”ҳ

manual() {

  wifi=$(rofi -config $rofidmenu -dmenu -i -p "Enter Wifi Name")

  [ -z "$wifi" ] && exit
  nopass="Run Without Password"
  pass=$(printf "$nopass\nCancel" | rofi -config $rofipass -dmenu -i -password -p "Wifi Password")

  if [ "$pass" = "" ]; then
    exit
  elif [ "$pass" = "$nopass" ]; then
    nmcli dev wifi con "$wifi" && printf "exit" | rofi -config $rofiprompt -dmenu -i -only-match -p "Successfully Connected to $wifi" && exit
  elif [ "$pass" = "Cancel" ]; then
    exit
  else
    nmcli dev wifi con "$wifi" password "$pass" && printf "exit" | rofi -config $rofiprompt -dmenu -i -only-match -p "Successfully Connected to $wifi" && exit
  fi

  printf "exit" | rofi -config $rofiprompt -dmenu -only-match -i -p "Failed to Connect $wifi" && exit
}

# в”Ңв”Җв”җв”Ңв”Җв”җв”Ңв”¬в”җв”¬в”Ңв”Җв”җв”Ңв”җв”Ңв”Ңв”Җв”җ
# в”Ӯ в”Ӯв”ңв”Җв”ҳ в”Ӯ в”Ӯв”Ӯ в”Ӯв”Ӯв”Ӯв”Ӯв””в”Җв”җ
# в””в”Җв”ҳв”ҙ   в”ҙ в”ҙв””в”Җв”ҳв”ҳв””в”ҳв””в”Җв”ҳ

options="$powertoggle\nConnections\nConnect Manually"

rofiwifi=$(printf "$options" | rofi -config $rofiprompt -dmenu -i -hover-select -p "Wifi
Powered: $power
Status: $wifi_display_status")

case $rofiwifi in
$powertoggle)
  powerswitch
  ;;
Connections)
  notify-send "Scanning"
  connections
  ;;
"Connect Manually")
  manual
  ;;
esac 2>/dev/null

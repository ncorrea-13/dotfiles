# Startup Applications
xwayland lazy

# autotiling
exec  autotiling

# exec dunst to show notifications
exec dunst

# syncthing for server sync
exec syncthing --no-browser

# polkit for fingerprint
exec /usr/libexec/polkit-mate-authentication-agent-1

# sway fader for smooth transitions
exec --no-startup-id sway-fader -d 100ms

# wallpaper
exec_always  swaybg -i ~/Pictures/Wallpapers/Wallpaper.jpg -m fill

# little script to lock the screen
exec_always  ~/.config/sway/scripts/lock.sh

input type:keyboard {
    xkb_layout latam
  }
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
    scroll_method two_finger
    click_method clickfinger
}
